{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {},
  "permissions": {
    "allow": [
      "Bash(git add:*)"
    ],
    "ask": [],
    "deny": [
      "Read(*.env)",
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "haiku",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
