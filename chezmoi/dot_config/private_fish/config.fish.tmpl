# ghq wrapper: `ghq get <repo>` clones flat into (ghq root)/<repo-name>
# without the <host>/<user> directory hierarchy. Other subcommands pass
# through to the real ghq. Supports -u/--update, --shallow, -b/--branch.
function ghq
    if test (count $argv) -eq 0; or test $argv[1] != get
        command ghq $argv
        return
    end

    set -l root (command ghq root)
    set -l clone_args
    set -l update false
    set -l specs
    set -l args $argv[2..-1]
    set -l i 1
    while test $i -le (count $args)
        set -l arg $args[$i]
        switch $arg
            case -u --update
                set update true
            case --shallow
                set -a clone_args --depth 1
            case -b --branch
                set i (math $i + 1)
                set -a clone_args --branch $args[$i]
            case --no-recursive
                # submodules are not cloned by default; nothing to do
            case '-*'
                echo "ghq (flat wrapper): ignoring unsupported flag '$arg'" >&2
            case '*'
                set -a specs $arg
        end
        set i (math $i + 1)
    end

    if test (count $specs) -eq 0
        echo "ghq get: no repository specified" >&2
        return 1
    end

    for spec in $specs
        set -l url $spec
        if not string match -qr '^(https?://|git@|ssh://|git://)' $spec
            # shorthand: user/repo or host/user/repo
            set -l parts (string split / $spec)
            switch (count $parts)
                case 2
                    set url git@github.com:$spec.git
                case 3
                    set url git@$parts[1]:$parts[2]/$parts[3].git
                case '*'
                    echo "ghq get: cannot parse '$spec'" >&2
                    continue
            end
        end

        set -l name (string replace -r '\.git$' '' (basename $spec))
        set -l dst $root/$name

        if test -d $dst
            if $update
                echo "update $dst"
                git -C $dst pull --ff-only
            else
                echo "exists $dst"
            end
            continue
        end

        echo "clone $url -> $dst"
        git clone $clone_args -- $url $dst
    end
end

function get_local_ip_address
    ifconfig | grep 'inet ' | grep -v 127.0.0.1 | awk '{print $2}'
end

function colors_swatch
    for i in (seq 0 255)
        printf "\e[48;5;%sm  \e[0m\e[38;5;%sm%03d\e[0m " $i $i $i
        if test (math "$i % 6") -eq 3
            echo
        end
    end
end

function colors_table
    set T 'awesome'  # The test text

    echo -e "\n                 40m     41m     42m     43m        44m     45m     46m     47m"

    for FGs in '    m' '   1m' '  30m' '1;30m' '  31m' '1;31m' '  32m' '1;32m' '  33m' '1;33m' '  34m' '1;34m' '  35m' '1;35m' '  36m' '1;36m' '  37m' '1;37m'
        set FG (string replace -a ' ' '' $FGs)
        printf " %s \033[%s  %s  " $FGs $FG $T
        for BG in 40m 41m 42m 43m 44m 45m 46m 47m
            printf "\033[%s\033[%s  %s  \033[0m" $FG $BG $T
        end
        echo
    end
    echo
end

