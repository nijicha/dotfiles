{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      // "*": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "rm *": "ask"
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    }
  }
}
